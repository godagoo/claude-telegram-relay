# ============================================================
# GENTECH BOT — CONFIGURATION BACKUP TEMPLATE
# ============================================================
#
# INSTRUCTIONS:
# 1. Fill in all your API keys and config below
# 2. Save this file securely (password manager, encrypted storage, etc.)
# 3. If your .env is lost, copy this file to .env and you're ready to go
# 4. Keep this updated when you add new keys or change settings
#
# WARNING: This file contains secrets! Do NOT commit to git or share publicly.
# Add .env.backup-template to .gitignore if you plan to store it locally.
# ============================================================

# --- TELEGRAM (REQUIRED) ---
# Get these from Telegram BotFather and @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# --- AI MODE ---
# Option 1: Claude CLI (uses your Pro/Max subscription, recommended)
CLAUDE_PATH=claude

# Option 2: Anthropic API (direct API access with tool_use)
# Uncomment and fill in if using API mode instead of CLI
# ANTHROPIC_API_KEY=

# --- SUPABASE (for memory, auth, cron jobs) ---
# Create free project at supabase.com
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- PERSONALIZATION ---
# Your name and timezone (used in bot responses)
USER_NAME=
USER_TIMEZONE=America/New_York

# --- TELEGRAM GROUP POSTING (NEW) ---
# Group chat ID for posting scheduled reports (crypto snapshots, etc.)
# Get from @userinfobot in the group (format: -1001234567890)
GENTECH_GROUP_ID=

# --- VOICE TRANSCRIPTION (optional) ---
# Choose provider: "groq" (cloud, free) or "local" (offline, requires whisper-cpp)
VOICE_PROVIDER=groq

# For Groq: Get free key at console.groq.com
GROQ_API_KEY=

# For local Whisper: Paths to whisper binary and model file
# WHISPER_BINARY=whisper-cpp
# WHISPER_MODEL_PATH=~/whisper-models/ggml-base.en.bin

# --- WEB SEARCH (optional but recommended) ---
# Brave Search API: 2000 free queries/month at brave.com/search/api
BRAVE_API_KEY=

# --- CRYPTO & BLOCKCHAIN (optional) ---
# CoinMarketCap: Get free key at coinmarketcap.com/api
# Required for: crypto watchlist cron job, price queries
COINMARKETCAP_API_KEY=

# Etherscan: For EVM blockchain data (gas, contract source)
# ETHERSCAN_API_KEY=

# Solscan: For Solana blockchain data
# SOLSCAN_API_KEY=

# Helius: For Solana RPC (optional, improves reliability)
# HELIUS_API_KEY=

# --- PATHS (optional) ---
# Where the bot stores data locally (logs, temp files, uploads)
# Default: ~/.claude-relay
# RELAY_DIR=~/.claude-relay

