# ============================================================
# Claude Telegram Relay — Environment Variables
# ============================================================
# Copy to .env:  cp .env.example .env
# Then fill in your values below.
# ============================================================

# --- REQUIRED: Telegram ---

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Your Telegram user ID (from @userinfobot)
TELEGRAM_USER_ID=your_telegram_user_id

# --- OPTIONAL: Supabase (history/search layer) ---

# Obsidian is the durable memory source of truth by default. Supabase can be
# added for Telegram message history and semantic search without competing
# with Obsidian.
MEMORY_AUTHORITY=obsidian

# Enable Supabase message persistence and relevant-context search when
# SUPABASE_URL and SUPABASE_ANON_KEY are configured.
SUPABASE_MESSAGE_HISTORY=1
SUPABASE_RELEVANT_CONTEXT=1

# Project URL (looks like https://abc123.supabase.co)
# SUPABASE_URL=your_project_url

# Supabase key. The relay reads SUPABASE_ANON_KEY for historical reasons,
# but the configured RLS policies (db/schema.sql) only grant access to the
# service_role. Use your service_role key here (starts with eyJ... and ends
# with `.service_role.<signature>` when decoded). Never expose this value;
# it bypasses Row Level Security entirely.
# SUPABASE_ANON_KEY=your_service_role_key

# --- RECOMMENDED: Personalization ---

# Your first name
USER_NAME=Your Name

# Your timezone (IANA format: America/New_York, Europe/Berlin, etc.)
USER_TIMEZONE=UTC

# --- OPTIONAL: Paths ---

# Claude CLI path (auto-detected if in PATH)
# CLAUDE_PATH=claude

# Working directory for Claude (defaults to relay's own directory)
# PROJECT_DIR=/path/to/your/project

# Relay data directory (defaults to ~/.claude-relay)
# RELAY_DIR=~/.claude-relay

# Pin the Python 3 interpreter used for contact resolution.
# Run `bun run setup:verify` to see which python3 launchd finds on its
# restricted PATH. If it differs from your shell's python3, set this to the
# full path that both environments agree on (e.g. /usr/local/bin/python3).
# RELAY_PYTHON=/usr/local/bin/python3

# iMessage staging handle. The relay sends CLDRAFT/1 payloads to this handle;
# a Shortcuts Message automation watches that staging thread and opens the
# target compose sheet with Show When Run enabled. Keep this different from
# the final target recipient; the helper refuses to leak CLDRAFT/1 JSON to the
# actual recipient unless you explicitly opt into self-staging.
# RELAY_IMESSAGE_STAGING_HANDLE=+15555555555
# RELAY_IMESSAGE_ALLOW_SELF_STAGING=0

# Legacy diagnostic only. Leave off for production/remote use: a Mac that is
# somewhere else cannot drive the user's iPhone.
RELAY_IPHONE_MIRROR_PLACEMENT=0

# --- OPTIONAL: Voice Transcription ---

# Voice provider: "groq" (free cloud API) or "local" (whisper.cpp on your machine)
# VOICE_PROVIDER=groq

# For Groq: Free API key from console.groq.com
# GROQ_API_KEY=your_groq_key

# For local whisper.cpp:
# WHISPER_BINARY=whisper-cpp
# WHISPER_MODEL_PATH=~/whisper-models/ggml-base.en.bin
