# ============================================================
# Gentech Telegram Bot — Environment Variables
# ============================================================
# Copy to .env:  cp .env.example .env
# Then fill in your values below.
# ============================================================

# --- REQUIRED ---

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Your Telegram user ID — this is the bot OWNER (from @userinfobot)
TELEGRAM_OWNER_ID=your_telegram_user_id

# --- AI MODE ---

# CLI Mode (default): Uses your Claude Pro/Max subscription via Claude Code CLI
# Skills (web search, DeFi, YouTube, smart contracts) work via auto-detection
# Requires: npm install -g @anthropic-ai/claude-code
CLAUDE_PATH=claude

# Optional: Anthropic API key for direct API mode (enables native tool_use)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# --- SUPABASE (memory, auth, cron persistence) ---

# Project URL (looks like https://abc123.supabase.co)
SUPABASE_URL=your_project_url

# anon public key (starts with eyJ...)
SUPABASE_ANON_KEY=your_anon_key

# --- PERSONALIZATION ---

# Your first name
USER_NAME=Your Name

# Your timezone (IANA format: America/New_York, Europe/Berlin, etc.)
USER_TIMEZONE=UTC

# --- VOICE TRANSCRIPTION ---

# Voice provider: "groq" (free cloud API) or "local" (whisper.cpp)
VOICE_PROVIDER=groq

# For Groq: Free API key from console.groq.com
GROQ_API_KEY=your_groq_key

# For local whisper.cpp:
# WHISPER_BINARY=whisper-cpp
# WHISPER_MODEL_PATH=~/whisper-models/ggml-base.en.bin

# --- WEB SEARCH ---

# Brave Search API — 2000 free queries/month
# Get a key at brave.com/search/api
# BRAVE_API_KEY=your_brave_api_key

# --- BLOCKCHAIN / DEFI (optional — free tiers work without keys) ---

# Etherscan API key (for EVM gas prices, contract source)
# ETHERSCAN_API_KEY=your_etherscan_key

# Solscan API key (for Solana on-chain data)
# SOLSCAN_API_KEY=your_solscan_key

# Helius API key (for Solana RPC, optional)
# HELIUS_API_KEY=your_helius_key

# --- PATHS (optional) ---

# Relay data directory (defaults to ~/.claude-relay)
# RELAY_DIR=~/.claude-relay
